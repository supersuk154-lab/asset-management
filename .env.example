# ── 인터뷰 서버 환경변수 ──────────────────────────────────────────────────────
# 이 파일을 .env로 복사한 후 실제 값으로 채우세요.
# Railway 배포 시에는 Railway 대시보드 Variables 탭에 직접 입력합니다.

# [필수] Gemini API 키 (Google AI Studio에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# [선택] Google Drive 연동 — responses.csv 자동 저장
# Google Cloud Console → 서비스 계정 키 JSON을 한 줄로 직렬화한 문자열
# 예: python -c "import json; print(json.dumps(json.load(open('key.json'))))"
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# [선택] Drive에서 responses.csv 파일의 ID
# Google Drive에서 파일 우클릭 → 공유 → 링크 복사 → URL 중 /d/<여기>/view 부분
GOOGLE_DRIVE_RESPONSES_CSV_FILE_ID=your_file_id_here

# ── 기존 파이프라인 환경변수 (참고용) ─────────────────────────────────────────
# FRED_API_KEY=your_fred_key
# ECOS_API_KEY=your_ecos_key
# ANTHROPIC_API_KEY=your_anthropic_key
